{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "dist",
      "node_modules",
      "coverage",
      "*.d.ts",
      "site",
      "launch",
      ".wrangler",
      ".eve",
      ".workflow-data",
      "examples/token-refresh-correctness/.b.json",
      "examples/token-refresh-correctness/.c.json",
      "examples/token-refresh-correctness/.d.json"
    ]
  },
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  },
  "overrides": [
    {
      "include": ["**/test/**", "**/*.test.ts", "examples/**"],
      "linter": {
        "rules": {
          "style": { "noNonNullAssertion": "off" }
        }
      }
    }
  ]
}
