{
  "name": "nominee",
  "version": "1.1.0",
  "description": "Identity and token delegation for AI agents — the provider-neutral auth layer for agents that act on your behalf",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "auth",
    "oauth",
    "token",
    "identity",
    "delegation",
    "token-vault",
    "human-in-the-loop"
  ],
  "author": "Bharath",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bharath31/nominee.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/bharath31/nominee#readme",
  "bugs": "https://github.com/bharath31/nominee/issues",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
