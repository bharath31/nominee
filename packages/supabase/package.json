{
  "name": "nominee-supabase",
  "version": "2.0.0",
  "description": "Supabase strategy for nominee — read and refresh provider tokens stored in Supabase for AI agents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "supabase",
    "postgres",
    "ai",
    "agents",
    "auth",
    "token",
    "nominee"
  ],
  "author": "Bharath",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bharath31/nominee.git",
    "directory": "packages/supabase"
  },
  "homepage": "https://github.com/bharath31/nominee#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "nominee": ">=2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "nominee": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
