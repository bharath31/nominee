{
  "name": "nominee-ai",
  "version": "1.0.0",
  "description": "Nominee adapter for the Vercel AI SDK — fresh tokens and human-in-the-loop approval for AI SDK tools",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "vercel",
    "ai-sdk",
    "ai",
    "agents",
    "auth",
    "token",
    "nominee"
  ],
  "author": "Bharath",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bharath31/nominee.git",
    "directory": "packages/ai"
  },
  "homepage": "https://github.com/bharath31/nominee#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "nominee": ">=1.0.0",
    "ai": "^5 || ^6",
    "zod": "^3.23.8 || ^4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "ai": "^6.0.0",
    "nominee": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  }
}
