# Reference only. `pnpm setup` writes the real values to .env.local (which Eve
# reads and hot-reloads). You normally don't edit this file by hand.

# Vercel AI Gateway — Eve routes model calls through it.
# `pnpm setup` runs `eve link` to populate this; or paste a key from
# https://vercel.com/dashboard/ai/api-keys
AI_GATEWAY_API_KEY=

# GitHub token for Levels 1 & 2 — the merge-access broker uses it to merge.
# `pnpm setup` captures it from `gh auth token`.
GITHUB_TOKEN=

# Optional: port for the merge-access broker (default 4778). If you set this,
# set it as a SHELL env var so both `pnpm broker` and `pnpm dev` see it.
# BROKER_PORT=4778

# Auth0 (Level 3 only) — Token Vault (fresh GitHub token) + CIBA (push approval).
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_REFRESH_TOKEN=
AUTH0_USER_SUB=
