# Vercel AI Gateway (Eve routes model calls through it). Create a key at
# https://vercel.com/dashboard/ai/api-keys  — or run `eve link` instead.
AI_GATEWAY_API_KEY=

# Auth0 — leave ALL of these blank to run in zero-setup MOCK mode.
# `pnpm setup` fills them in for REAL Token Vault + CIBA.
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_REFRESH_TOKEN=
AUTH0_USER_SUB=
